{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyOrgAccess",
      "Effect": "Deny",
      "Action": [
        "organizations:*"
      ],
      "Resource": "*",
      "Condition": {
        "StringNotEquals": {
          "aws:PrincipalAccount": "<SECURITY_TOOLS_ACCOUNT_ID>"
        },
        "BoolIfExists": {
          "aws:PrincipalIsAWSService": "false"
        }
      }
    }
  ]
}
