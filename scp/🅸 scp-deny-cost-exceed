{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DenyHighCostInstanceFamily",
      "Effect": "Deny",
      "Action": "ec2:RunInstances",
      "Resource": "arn:aws:ec2:*:*:instance/*",
      "Condition": {
        "StringLike": {
          "ec2:InstanceType": [
            "p*",
            "x*",
            "u*",
            "g*",
            "inf*",
            "trn*",
            "hpc*"
          ]
        }
      }
    }
  ]
}
